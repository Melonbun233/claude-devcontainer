# ── GitHub Servers ────────────────────────────────────────────────────────────
# List of GitHub servers to authenticate against.
# Each entry defines a hostname, the env var holding its PAT,
# and optional git identity (user_name/user_email) for commits.
github_servers:
  - host: github.com
    token_env: GH_TOKEN
    # user_name: Jane Doe
    # user_email: jane@personal.com

  # Add enterprise servers as needed:
  # - host: github.enterprise.corp.com
  #   token_env: GH_ENTERPRISE_TOKEN
  #   user_name: Jane Doe
  #   user_email: jane.doe@corp.com

# ── Repos to Clone ──────────────────────────────────────────────────────────
# Each repo is cloned to /workspace/<target> on container start.
# The URL host must match one of the github_servers above for auth.
repos: []
  # - url: https://github.com/org/repo1
  #   branch: main
  #   target: repo1
  #
  # - url: https://github.enterprise.sap.com/team/service
  #   branch: develop
  #   target: service
