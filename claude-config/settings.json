{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(curl *)",
      "Bash(jq *)",
      "Bash(python3 *)",
      "Bash(yq *)",
      "Bash(make *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"Run /reload-plugins now to refresh all installed plugins and skills.\"}}'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
